# Tromsø live ISO installer image
#
# Build with:
#   just container tromso
#
# Three-stage build:
#   1. tromso-ref        — Tromsø OCI image (provides kernel modules)
#   2. initramfs-builder — Debian: builds a dmsquash-live initramfs against
#                          Tromsø's kernel modules
#   3. final             — Tromsø: receives the rebuilt initramfs + live-env setup
#
# Tromsø is KDE Plasma / freedesktop-sdk based — no package manager, no dracut.
# The initramfs is built in a separate Debian stage so no cross-distro binary
# grafting is needed; only the initramfs.img output crosses the stage boundary.
# The ISO bootloader is systemd-boot (already in Tromsø at
# /usr/lib/systemd/boot/efi/systemd-bootx64.efi) — no GRUB2 or shim required.

ARG BASE_IMAGE=ghcr.io/tuna-os/tromso:latest

# ── Stage 1: Tromsø reference (kernel modules source) ────────────────────────
FROM ${BASE_IMAGE} AS tromso-ref

# ── Stage 2: Debian — builds the dmsquash-live initramfs ─────────────────────
FROM debian:sid AS initramfs-builder

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        dracut \
        dmsetup \
        plymouth \
        plymouth-themes \
    && rm -rf /var/lib/apt/lists/*

COPY --from=tromso-ref /usr/lib/modules /usr/lib/modules

# Use the same breeze-bgrt theme as the installed OS (elements/tromso/
# plymouth-theme.bst) instead of Debian's default, so the live boot is
# branded consistently with an installed system.
COPY --from=tromso-ref /usr/share/plymouth/themes/breeze-bgrt /usr/share/plymouth/themes/breeze-bgrt
COPY --from=tromso-ref /usr/share/plymouth/plymouthd.defaults /usr/share/plymouth/plymouthd.defaults

COPY src/dracut/95tromso-isofile /usr/lib/dracut/modules.d/95tromso-isofile

RUN set -ex; \
    kernel=$(ls /usr/lib/modules | sort -V | tail -1); \
    echo "Building dmsquash-live initramfs for kernel ${kernel}"; \
    DRACUT_NO_XATTR=1 dracut -v --force --zstd --reproducible --no-hostonly \
        --add "dmsquash-live plymouth tromso-isofile" \
        --add-drivers "squashfs overlay loop iso9660 sr_mod cdrom sd_mod usb-storage xhci-pci exfat vfat fat ntfs3 ext4" \
        /tmp/initramfs.img "${kernel}"; \
    ls -lh /tmp/initramfs.img

# ── Stage 3: Final Tromsø live image ─────────────────────────────────────────
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG INSTALLER_CHANNEL=stable
ENV INSTALLER_CHANNEL=${INSTALLER_CHANNEL}

ARG DEBUG=0
ENV DEBUG=${DEBUG}

# Replace the OCI-mode initramfs with the dmsquash-live initramfs from stage 2
COPY --from=initramfs-builder /tmp/initramfs.img /tmp/initramfs.img
RUN kernel=$(ls /usr/lib/modules | sort -V | tail -1) && \
    mv /tmp/initramfs.img "/usr/lib/modules/${kernel}/initramfs.img" && \
    echo "Replaced initramfs for kernel ${kernel}"

# ── Flatpak install layer ─────────────────────────────────────────────────────
COPY src/flatpaks /tmp/flatpaks-list
RUN --mount=type=bind,source=src,target=/src \
    --mount=type=cache,target=/var/cache/flatpak-dl,id=tromso-flatpak \
    /src/install-flatpaks.sh

# ── Live-environment configure layer ─────────────────────────────────────────
COPY src/ /tmp/src/
RUN chmod +x /tmp/src/configure-live.sh && /tmp/src/configure-live.sh
